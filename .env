# Server
SERVER_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json
GIN_MODE=release

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth_service
DATABASE_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5440/${POSTGRES_DB}?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=10
DB_MAX_IDLE_TIME=15m
DB_MAX_LIFETIME=30m
DB_PING_TIMEOUT=5s

# Server timeouts
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s

# JWT
JWT_SECRET=d9e5a5005257622cfe05554fbce24733c6766e63c4c3504d105e5d10780a8826
JWT_EXPIRATION=12 // in hours
JWT_REFRESH_EXPIRATION=7 // in days
